# Maintainer: replace with your AUR account
pkgname=tlm
pkgver=0.2.0b2
pkgrel=1
pkgdesc="Terminal LLM helper (Linux CLI)"
arch=('any')
url="https://github.com/OWNER/tlm"
license=('Apache-2.0')
depends=('python' 'python-httpx' 'python-rich' 'python-dotenv')
makedepends=('python-build' 'python-installer' 'python-wheel')
source=("$pkgname-$pkgver.tar.gz::https://github.com/OWNER/tlm/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
  cd "$srcdir/$pkgname-$pkgver"
  python -m build --wheel --no-isolation
}

package() {
  cd "$srcdir/$pkgname-$pkgver"
  python -m installer --destdir="$pkgdir" dist/*.whl
}
